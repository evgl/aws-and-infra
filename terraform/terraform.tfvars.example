# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real account IDs or IPs.

aws_region     = "ap-northeast-2"
aws_account_id = ""

project_name = "microservice"

# Restrict SSH access to your IP: run `curl ifconfig.me` to find it
my_ip = "1.2.3.4/32"

# Optional: name of an existing EC2 key pair for SSH access
# key_name = "my-key-pair"
